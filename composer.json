{
  "name": "gsu-dle/gadget-process",
  "description": "Gadget library for executing commands in sub-processes",
  "type": "library",
  "keywords": [],
  "homepage": "https://github.com/gsu-dle/gadget-process",
  "license": "MIT",
  "support": {
    "issues": "https://github.com/gsu-dle/gadget-process/issues",
    "wiki": "https://github.com/gsu-dle/gadget-process/wiki",
    "source": "https://github.com/gsu-dle/gadget-process"
  },
  "require": {
    "php": "^8.1",
    "ext-json": "*",
    "gsu-dle/gadget-core": "^1.0",
    "gsu-dle/symfony-bundle": "^1.0",
    "symfony/process": "6.4.*"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.0",
    "phpstan/phpstan-strict-rules": "^2.0",
    "phpstan/extension-installer": "^1.4",
    "squizlabs/php_codesniffer": "^3.10"
  },
  "autoload": {
    "psr-4": {
      "Gadget\\Process\\": [
        "src/",
        "bundle/"
      ]
    }
  },
  "config": {
    "allow-plugins": {
      "phpstan/extension-installer": true
    },
    "sort-packages": true,
    "optimize-autoloader": true,
    "apcu-autoloader": true
  },
  "scripts": {
    "phpcs": "vendor/bin/phpcs",
    "phpstan": "vendor/bin/phpstan analyse -c phpstan.neon"
  },
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/gsu-dle/gadget-core"
    },
    {
      "type": "vcs",
      "url": "https://github.com/gsu-dle/symfony-bundle"
    }
  ]
}
